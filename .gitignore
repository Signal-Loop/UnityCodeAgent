*.tmp
*.temp

# Rider
.idea/
*.sln.*

# Logs
*.log

# Unity generated scene temp files
*.pidb.meta

# Cache server
ServerSettings.asset

# Uncomment the following line to ignore crash reports
# crashlytics/

!**/CopilotService~/*.csproj
**/CopilotService~/bin/
**/CopilotService~/obj/

!CopilotService.Tests/*.csproj
/CopilotService.Tests/bin/
/CopilotService.Tests/obj/
/CopilotService.Tests/TestResults/

