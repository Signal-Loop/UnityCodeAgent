<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Packages/com.signal-loop.unitycodeagent/Editor/UI/ChatWindow.uss?fileID=7433441132597879392&amp;guid=d5556737ff93b3b49b7f1085484df43b&amp;type=3#ChatWindow"/>
    <ui:VisualElement class="chat-window">
        <ui:ScrollView name="scroll-view" class="chat-scroll-view"/>
        <ui:ScrollView name="sessions-scroll-view" class="chat-scroll-view chat-scroll-view--hidden"/>
        <ui:VisualElement class="chat-composer">
            <ui:TextField name="user-input" multiline="true" class="chat-input"/>
            <ui:VisualElement class="chat-actions">
                <ui:Button name="sessions-button" text="Sessions" class="chat-button"/>
                <ui:Button name="settings-button" text="Settings" class="chat-button"/>
                <ui:Button name="send-button" text="Send" class="chat-button chat-button--right"/>
            </ui:VisualElement>
            <ui:Label name="model-label" text="No model selected" class="chat-model-label"/>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
